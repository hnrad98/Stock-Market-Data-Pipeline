# Your GCP project ID (e.g. my-project-123)
GCP_PROJECT_ID=your-gcp-project-id

# GCS bucket name — must be globally unique across all of GCP
# Convention used here: stock-market-data-lake-{project-id}
GCS_BUCKET_NAME=stock-market-data-lake-your-gcp-project-id

# BigQuery dataset name — will be created by Terraform
BQ_DATASET=stock_market

# Path to the directory containing your GCP service account key JSON
# Place your key file at ./keys/gcp-key.json
# The file itself is gitignored — never commit it
GCP_KEY_PATH=./keys
